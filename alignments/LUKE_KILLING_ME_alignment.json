  "segments": [
    {
      "index": 0,
      "start": 23.907,
      "end": 26.309,
      "text": "Used to think you'd be the one I'd get a mortgage with",
      "y_offset": 0,
      "words": []
    },
    {
      "index": 1,
      "start": 26.629,
      "end": 29.553,
      "text": "You had me head over heels like a contortionist",
      "y_offset": 0,
      "words": []
